<div class="container py-4">
  <div class="row">
    <div class="col-11 col-md-11 col-lg-10 mx-auto">
      <div class="terms-page bg-white bg-opacity-50 rounded-3 p-4">
      <h2 class="float-left mb-5"><%= t('.title') %></h2>
      <p>
        <table class="table">
          <tr>
            <th scope="row"><%= User.human_attribute_name(:email) %></th>
            <td><%= current_user.email %></td>
          </tr>
          <tr>
            <th scope="row"><%= User.human_attribute_name(:name) %></th>
            <td><%= current_user.name %></td>
          </tr>
          <tr>
            <th scope="row"><%= User.human_attribute_name(:avatar) %></th>
            <td><%= image_tag current_user.image_url, class: 'rounded-circle', size: '50x50' %></td>
          </tr>
        </table>
      </p>
      <p><%= link_to t('defaults.profile_edit'), edit_profile_path, class: 'btn btn-secondary' %></p>
    </div>
  </div>
</div>
