<div id="comment-form">
  <%= form_with model: comment, url: board_comments_path(board) do |f| %>
    <%= render 'shared/error_messages', object: f.object %>
    <%= f.text_area :body, class: "form-control mb-3", rows: 2, placeholder: Comment.human_attribute_name(:body) %>
    <div class="text-end">
      <%= f.submit t('comments.post'), class: "btn btn-info" %>
    </div>
  <% end %>
</div>
