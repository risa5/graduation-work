<% content_for(:title, t('.title')) %>

<div class="container py-4">
  <script src="https://accounts.google.com/gsi/client" async defer></script>

    <div class="row">
      <div class="col-12 col-lg-11 mx-auto">

        <!-- タイトル -->
        <h2><%= t('.title') %></h2>

            <!-- 通常ログインフォーム -->
            <div class="bg-white bg-opacity-50 rounded-3 py-4 my-3">
              <div class="row">
                <div class="col-11 col-lg-10 mx-auto text-center">

                  <%= form_with url: login_path, method: :post, local: true do |f| %>
                  <!-- メールアドレス入力欄 -->
                  <div class="mb-3">
                    <!-- メールアドレスのラベル -->
                    <%= f.label :email %>
                    <!-- メールアドレスの入力フィールド -->
                    <%= f.email_field :email, class: "form-control" %>
                  </div>
                  <!-- パスワード入力欄 -->
                  <div class="mb-3">
                    <!-- パスワードのラベル -->
                    <%= f.label :password %>
                    <!-- パスワードの入力フィールド -->
                    <%= f.password_field :password, class: "form-control" %>
                  </div>

                  <!-- ログインボタン -->
                  <%= f.submit "ログイン", class: "btn btn-secondary" %>

                  <!-- ログイン状態の保持 -->
                  <div>
                    <%= check_box_tag :remember, params[:remember], true %>
                    <%= label_tag :remember, 'ログイン状態を保持する' %>
                  </div>

                </div>
              </div>
            </div>

              <!-- googleログインフォーム -->
              <div class="bg-white bg-opacity-50 rounded-3 py-4 my-3">
               <div class="row">
                <div class="col-11 col-lg-10 mx-auto text-center">

                  <div class="badge text-bg-primary m-2 fs-7">Googleアカウントで会員登録した方はこちら</div>
                    <div class="m-3">
                      <div id="g_id_onload"
                        data-client_id="811707880125-2sm1k1amvipajslkhgrgnr5aet02ta68.apps.googleusercontent.com"
                        data-login_uri="http://localhost:3000/google_login_api/callback"
                        data-auto_prompt="false">
                      </div>
                      <div class="g_id_signin"
                        data-type="standard"
                        data-size="large"
                        data-theme="outline"
                        data-text="sign_in_with"
                        data-shape="rectangular"
                        data-logo_alignment="left">
                      </div>
                    </div>
                    <% end %>
                  </div>
                </div>
              </div>


        <!-- パスワード再設定ボタン -->
        <div class="text-center">
          <%= link_to 'パスワードをお忘れの方', new_password_reset_path %>
        </div>
        <!-- 新規登録ボタン -->
        <div class='text-end'>
          <%= link_to t('user_sessions.new.to_register_page'), new_user_path, class: 'btn btn-secondary' %>
        </div>
    </div>
  </div>
</div>
