<% content_for(:title, t('.title')) %>

<div class="container py-4">
  <div class="row">
    <div class="col-11 col-md-10 mx-auto">
    
      <!-- タイトル -->
      <h2><%= t('.title') %></h2>

      <div class="bg-white bg-opacity-50 rounded-3 p-4 my-3">

        <div class="row">
          <div class="col-11 mx-auto">
            <!-- 編集フォーム -->
            <%= form_with model: @user, url: admin_user_path(@user), method: :patch do |f| %>
            <%= render 'shared/error_messages', object: f.object %>

              <!-- email -->
              <div class="mb-3">
                <%= f.label :email, class: "form-label" %>
                <%= f.email_field :email, class: "form-control" %>
              </div>

              <!-- 名前 -->
              <div class="mb-3">
                <%= f.label :name, class: "form-label" %>
                <%= f.text_field :name, class: "form-control" %>
              </div>

              <!-- 権限 -->
              <div class="mb-3">
                <%= f.label :role, class: "form-label" %>
                <%= f.select :role, User.roles_i18n.map{|key, value| [value, key]}, { class: 'form-control mr-1' } %>
              </div>

              <!-- アイコン -->
              <div class="mb-3">
                <%= f.label :image %>
                <%= f.file_field :image, class: 'form-control mb-3', accept: 'image/*' %>
                <%= f.hidden_field :image_cache %>
                <div class='mt-3 mb-3'>
                  <%= image_tag @user.image.url,
                                class: 'rounded-circle border border-secondary border border-2',
                                size: '100x100' %>
                </div>
              </div>
              <div class="text-end">
                <%= f.submit t('defaults.profile_update'), class: "btn btn-outline-success" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
        
        <!-- 戻るボタン -->
        <div class='m-3'>
          <%= link_to "ユーザー表示画面へ戻る", admin_user_path, class: 'btn btn-success float-end' %>
        </div>
    </div>
  </div>
</div>
