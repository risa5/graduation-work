<% content_for(:title, t('.title')) %>

<div class="container py-4">
  <div class="row">
    <div class="col-12 col-md-11 col-lg-10 mx-auto">
      <h2><%= t('.title') %></h2>

      <table class="table">
        <tr>
          <th scope="row"><%= User.human_attribute_name(:email) %></th>
          <td><%= @user.email %></td>
        </tr>
        <tr>
          <th scope="row"><%= User.human_attribute_name(:name) %></th>
          <td><%= @user.name %></td>
        </tr>
        <tr>
          <th scope="row"><%= User.human_attribute_name(:role) %></th>
          <td><%= @user.role %></td>
        </tr>
        <tr>
          <th scope="row"><%= User.human_attribute_name(:avatar) %></th>
          <td><%= image_tag @user.image_url, class: 'rounded-circle', size: '50x50' %></td>
        </tr>
      </table>

      <div class="my-3 text-end">
        <%= link_to t('defaults.edit'), edit_admin_user_path(@user), class: 'btn btn-outline-success' %>
      </div>

      <div class="my-3 text-end">
        <%= link_to "ユーザー管理画面へ戻る", admin_users_path, class: 'btn btn-secondary float-end' %>
      </div>
    </div>
  </div>
</div>
