<% content_for(:title, t('.title')) %>

<div class="container py-4">
  <div class="row">
    <div class="col-12 col-md-11 mx-auto">
    
      <!-- タイトル -->
      <h2><%= t('.title') %></h2>

      <!-- ユーザー情報 -->
      <div class="bg-white bg-opacity-50 rounded-3 py-4 my-1">
        <div class="row">
          <div class="col-11 mx-auto">

            <!-- 画像 -->
            <div class="mb-3 text-center">
              <%= image_tag @user.image_url, class: 'rounded-circle border border-info border-3', size: '100x100' %>
            </div>

            <!-- 名前 -->
            <div class="mb-3 text-center">
              <div class="text-muted text-decoration-underline text-info-emphasis"><%= User.human_attribute_name(:name) %></div>
              <div class="fw-bold fs-5"><%= @user.name %></div>
            </div>

            <!-- メールアドレス -->
            <div class="mb-3 text-center">
              <div class="text-muted text-decoration-underline text-info-emphasis"><%= User.human_attribute_name(:email) %></div>
              <div class="fw-bold fs-5"><%= @user.email %></div>
            </div>
            
            <!-- 権限 -->
            <div class="mb-3 text-center">
              <div class="text-muted text-decoration-underline text-info-emphasis"><%= User.human_attribute_name(:role) %></div>
              <div class="fw-bold fs-5"><%= t("enums.user.role.#{@user.role}") %></div>
            </div>

            <!-- 編集ボタン -->
            <div class="my-1 text-end">
              <%= link_to t('defaults.profile_edit'), edit_admin_user_path(@user), class: 'btn btn-outline-success' %>
            </div>
          </div>
        </div>
      </div>

      <!-- 戻るボタン -->
      <div class="my-3 text-end">
        <%= link_to "ユーザー管理画面へ戻る", admin_users_path, class: 'btn btn-secondary float-end' %>
      </div>
    </div>
  </div>
</div>
