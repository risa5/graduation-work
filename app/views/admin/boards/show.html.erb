<% content_for(:title, t('.title')) %>

<div class="container py-4">
  <div class="row">
    <div class="col-11 col-md-10 col-lg-9 mx-auto">
      <h2><%= t('.title') %></h2>

      <div class="board_show bg-white rounded-3 p-4">

        <!-- カードコンテナ -->
        <article class="card mx-2 my-2">

          <!-- カード内容 -->
          <div class="card-body">
            <div class="row">

              <!-- 画像表示 -->
              <div class="col-md-3">
                <%= image_tag @board.board_image_url, width: "300", height: "200", class: "card-img-top img-fluid" %>
              </div>

              <!-- タイトル表示 -->
              <div class="col-md-9">
                <h3 style="display: inline;"><%= @board.title %></h3>

                <!-- アカウント名・投稿日・いいね数 -->
                <ul class="list-inline">
                  <li class="list-inline-item">
                    <i class="bi bi-person me-1"></i>
                    <%= @board.user.name %>
                  </li>
                  <li class="list-inline-item">
                    <i class="bi bi-calendar me-1"></i>
                    <%= @board.created_at.strftime("%Y/%m/%d %H:%M") %>
                  </li>
                  <li class="list-inline-item">
                    <i class="bi bi-hearts me-1"></i>
                    <%= "いいね数: #{@board.likes.count}" %>
                  </li>
                </ul>
              </div>

              <!-- 本文 -->
              <div class="py-3">
                <%= simple_format(@board.body) %>
              </div>

            </div>
          </div>
        </article>
      </div>

      <!-- 編集・削除ボタン -->
      <div class="d-flex justify-content-end gap-2 mb-3 py-3">
        <%= link_to "編集", edit_admin_board_path(@board), class: 'btn btn-outline-success' %>
        <%= link_to "削除", admin_board_path(@board), data: { turbo_method: :delete, turbo_confirm: t('defaults.delete_confirm') }, class: 'btn btn-outline-danger' %>
      </div>

      <!-- 戻るボタン -->
      <div class='mt-3 mb-3'>
        <%= link_to "掲示板管理画面へ戻る", admin_boards_path, class: 'btn btn-success float-end' %>
      </div>
    </div>
  </div>
</div>
